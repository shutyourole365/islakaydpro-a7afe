# Supabase (required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Enable the AI assistant in the frontend (set to "true" to use the Edge Function)
VITE_ENABLE_AI=true

# LLM provider keys (optional - required to use real LLMs)
# Add one or both depending on your preferred provider
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=...

# To run Supabase Edge Functions locally you will need a service role key
SUPABASE_SERVICE_ROLE_KEY=service-role-...
