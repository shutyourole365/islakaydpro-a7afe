{
  "name": "islakayd",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "mkdir -p .vitest_tmp && TMPDIR=$PWD/.vitest_tmp vitest",
    "test:ui": "mkdir -p .vitest_tmp && TMPDIR=$PWD/.vitest_tmp vitest --ui",
    "test:coverage": "mkdir -p .vitest_tmp && TMPDIR=$PWD/.vitest_tmp vitest --coverage",
    "test:unit": "mkdir -p .vitest_tmp && TMPDIR=$PWD/.vitest_tmp vitest --run src/__tests__",
    "test:run": "mkdir -p .vitest_tmp && TMPDIR=$PWD/.vitest_tmp vitest run",
    "deploy": "npm run build && vercel --prod",
    "deploy:staging": "npm run build && vercel --staging",
    "preview:build": "npm run build && npm run preview",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "clean": "rm -rf dist node_modules/.vite",
    "postinstall": "npm run typecheck"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@sentry/react": "^10.38.0",
    "@supabase/supabase-js": "^2.57.4",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@eslint/plugin-kit": "^0.5.1",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/aria-query": "^5.0.4",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/chai": "^5.2.3",
    "@types/deep-eql": "^4.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.7",
    "@types/sanitize-html": "^2.16.0",
    "@types/slice-ansi": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.18",
    "axe-core": "^4.11.1",
    "csstype": "^3.2.3",
    "dotenv": "^17.2.3",
    "eslint": "^10.0.1",
    "globals": "^15.9.0",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
